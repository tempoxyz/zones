sequenceDiagram
    participant R as "Receiver"
    participant I as "Handoff Identity API"
    participant T as "Handoff Settlement API"
    participant S as "Sender"
    participant P as "Tempo L1 / ZonePortal"
    participant Z as "Zone RPC"

    R->>I: "Start registration for user@example.com"
    I-->>R: "recipient_id + dev verification code"
    R->>I: "Complete registration with signed recipient cert"
    R->>T: "Link hidden zone address + route secret"
    S->>I: "Resolve identifier and amount"
    I-->>S: "Recipient cert + resolve token"
    S->>T: "Mint one-time route"
    T->>P: "Read sequencer encryption key"
    T-->>S: "Signed route intent + encrypted payload"
    S->>P: "approve() + depositEncrypted(...)"
    P-->>Z: "Encrypted deposit is processed"
    Z-->>R: "Hidden balance increases"
