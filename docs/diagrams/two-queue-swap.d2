direction: down

title: {
  label: Two-Queue Withdrawal System
  near: top-center
  shape: text
  style.font-size: 24
  style.bold: true
}

# Initial state
initial: {
  label: "Initial State"
  style.fill: "#f5f5f5"
  style.stroke: "#9e9e9e"

  q1: {
    label: "queue1 (active)"
    style.fill: "#e3f2fd"
    style.stroke: "#2196F3"
    content: "hash(w1, hash(w2, 0))"
  }

  q2: {
    label: "queue2 (pending)"
    style.fill: "#fce4ec"
    style.stroke: "#E91E63"
    content: "hash(w3, hash(w4, 0))"
  }
}

# Processing
processing: {
  label: "Sequencer Processes queue1"
  style.fill: "#e8f5e9"
  style.stroke: "#4CAF50"

  action: |md
    1. Process w1 → queue1 = hash(w2, 0)
    2. Process w2 → queue1 = 0 (empty!)
  |
}

# After drain
after_drain: {
  label: "queue1 Empty"
  style.fill: "#fff3e0"
  style.stroke: "#FF9800"

  q1: {
    label: "queue1"
    style.fill: "#ffecb3"
    style.stroke: "#FFC107"
    content: "0 (empty)"
  }

  q2: {
    label: "queue2"
    style.fill: "#fce4ec"
    style.stroke: "#E91E63"
    content: "hash(w3, hash(w4, 0))"
  }
}

# Swap
swap: {
  label: "SWAP"
  shape: diamond
  style.fill: "#7c4dff"
  style.font-color: "#fff"
  style.font-size: 18
}

# Final state
final: {
  label: "After Swap"
  style.fill: "#e8f5e9"
  style.stroke: "#4CAF50"

  q1: {
    label: "queue1 (now active)"
    style.fill: "#c8e6c9"
    style.stroke: "#4CAF50"
    content: "hash(w3, hash(w4, 0))"
  }

  q2: {
    label: "queue2 (reset)"
    style.fill: "#fafafa"
    style.stroke: "#9e9e9e"
    content: "0"
  }
}

initial -> processing
processing -> after_drain
after_drain -> swap: "queue1 == 0"
swap -> final: |md
  queue1 = queue2
  queue2 = 0
|
