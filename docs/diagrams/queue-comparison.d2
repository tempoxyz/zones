direction: down

title: {
  label: Queue Design Comparison
  near: top-center
  shape: text
  style.font-size: 28
  style.bold: true
}

subtitle: {
  label: "Both FIFO • Both Constant Storage • Inverted Requirements"
  near: top-center
  shape: text
  style.font-size: 16
  style.font-color: "#666"
}

deposits: {
  label: "DEPOSIT QUEUE"
  style.fill: "#e3f2fd"
  style.stroke: "#1976D2"
  style.font-size: 20

  structure: {
    label: "Newest Outermost"
    shape: rectangle
    style.fill: "#bbdefb"

    chain: |md
      ```
      hash(d3, hash(d2, hash(d1, 0)))
           ↑                    ↑
        newest              oldest
      ```
    |
  }

  onchain: {
    label: "On-chain: ADD"
    shape: rectangle
    style.fill: "#c8e6c9"
    style.stroke: "#4CAF50"

    op: "Wrap outside O(1)"
  }

  proof: {
    label: "In ZKP: REMOVE"
    shape: rectangle
    style.fill: "#fff9c4"
    style.stroke: "#FBC02D"

    op: "Process from checkpoint"
  }

  structure -> onchain
  onchain -> proof
}

withdrawals: {
  label: "WITHDRAWAL QUEUE"
  style.fill: "#fce4ec"
  style.stroke: "#C2185B"
  style.font-size: 20

  structure: {
    label: "Oldest Outermost"
    shape: rectangle
    style.fill: "#f8bbd9"

    chain: |md
      ```
      hash(w1, hash(w2, hash(w3, 0)))
           ↑                    ↑
        oldest              newest
      ```
    |
  }

  onchain: {
    label: "On-chain: REMOVE"
    shape: rectangle
    style.fill: "#c8e6c9"
    style.stroke: "#4CAF50"

    op: "Unwrap outside O(1)"
  }

  proof: {
    label: "In ZKP: ADD"
    shape: rectangle
    style.fill: "#fff9c4"
    style.stroke: "#FBC02D"

    op: "Build queue O(N)"
  }

  structure -> onchain
  onchain -> proof
}

insight: {
  label: "KEY INSIGHT"
  shape: rectangle
  style.fill: "#7c4dff"
  style.font-color: "#fff"
  style.font-size: 16
  style.bold: true

  text: |md
    Structure the hash chain so the
    **on-chain operation touches the outermost layer**
  |
}

deposits -> insight
withdrawals -> insight
